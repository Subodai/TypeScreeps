{
  "name": "subodai-typescreeps",
  "version": "0.0.1",
  "description": "This project is an excercise in learning TypeScript and for converting my existing JS codebase over to it and improving on it.",
  "main": "index.js",
  "//": "If you add or change the names of destinations in screeps.json, make sure you update these scripts to reflect the changes",
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint \"src/**/*.ts\"",
    "push-main": "rollup -c --dest main",
    "push-pserver": "rollup -c --dest pserver",
    "push-sim": "rollup -c --dest sim",
    "test": "jest",
    "watch-main": "rollup -cw --dest main",
    "watch-pserver": "rollup -cw --dest pserver",
    "watch-sim": "rollup -cw --dest sim"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Subodai/TypeScreeps.git"
  },
  "author": "Mark Thompson",
  "license": "Unlicense",
  "bugs": {
    "url": "https://github.com/screepers/screeps-typescript-starter/issues"
  },
  "homepage": "https://github.com/Subodai/TypeScreeps#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@types/jest": "^29.5.12",
    "@types/screeps": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rollup": "^4.21.2",
    "rollup-plugin-delete": "^2.0.0",
    "rollup-plugin-screeps": "^1.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "source-map": "~0.6.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "screeps-profiler": "^2.0.1"
  }
}
